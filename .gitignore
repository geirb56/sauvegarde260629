# Ignore env, pyc, virtualenv
# NOTE: .env files are intentionally NOT ignored — Emergent deployment requires
# them to be present in the repository for auto-configuration.
__pycache__/
*.pyc
.idea/
.vscode/
instance/
*.db
credentials.json
*.pem
*.key
.credentials
# gccli: arch-specific binary (auto-downloaded at startup) and OAuth token store
backend/bin/
backend/.gccli_home/
.env
.env.*
*.env
